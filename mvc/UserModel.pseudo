/** CHANGE: Created UserModel to contain data and database operations, as well as to separate the model interface.
Reason: MVC places business logic and persistence inside the model. **/

public class UserModel {

    public createUser(username, password) {

        db = getDatabase("myHost", "myPassword", "myDb");

        success = db.query(
            "INSERT INTO users(username,password) VALUES(username,password)"
        );

        return success;
    }
}
